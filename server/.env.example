RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=
MARKETSTACK_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MEDIASTACK_API_KEY=
