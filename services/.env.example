# FastAPI services runtime
PORT=8000

# MongoDB (shared with the Node server)
MONGO_URL=mongodb://localhost:27017/fingenie

# Used to verify tokens issued by the Node server - must match server/.env JWT_SECRET
JWT_SECRET=change_me_to_a_long_random_string

# Local LLM (Qwen2.5-1.5B-Instruct)
LOCAL_LLM_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
LOCAL_LLM_DEVICE=auto
LOCAL_LLM_LOAD_IN_4BIT=true
LOCAL_LLM_MAX_NEW_TOKENS=512
LOCAL_LLM_TEMPERATURE=0.7
LOCAL_LLM_TOP_P=0.9

# Optional: enables /chatbot/chat and /chatbot/generate (Gemini-based)
GEMINI_API_KEY=

# Optional market data integrations - leave blank to disable the related features
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
MARKETSTACK_API_KEY=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
MEDIASTACK_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
